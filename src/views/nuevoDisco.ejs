<% include partials/_header %>

<div class="container">
<div class="row justify-content-center">
<div class="col-lg-8">
<div class="card shadow border-0 mt-4">
<div class="card-header cabecera">
    <h3 class="mb-0">
        💿 Añadir nuevo disco
    </h3>
</div>
<div class="card-body">
    <form action="/discos" method="post">
        <!-- Título -->
        <div class="form-group mb-3">
            <label for="">
                <strong>Título</strong>
            </label>
            <input type="text" name="titulo" class="form-control">
        </div>
        <!-- Año -->
        <div class="form-group mb-3">
            <label for="">
                <strong>Año</strong>
            </label>
            <input type="text" name="anyo" class="form-control">
        </div>
        <!-- Carátula -->
        <div class="form-group mb-3">
            <label for="">
                <strong>Carátula (URL)</strong>
            </label>
            <input type="text" name="caratula" class="form-control">
        </div>
        <!-- Info -->
        <div class="form-group mb-3">
            <label for="">
                <strong>Información</strong>
            </label>
            <textarea name="info" class="form-control"></textarea>
        </div>
        <!-- Intérprete -->
        <div class="form-group mb-3">
            <label for="">
                <strong>Intérprete</strong>
            </label>
            <select name="interprete" class="form-control" required>
                <option value="">-- Selecciona intérprete --</option>
                <% interpretes.forEach(interprete => { %>
                    <option value="<%= interprete._id %>">
                        <%= interprete.nombre %>
                    </option>
                <% }) %>
            </select>
        </div>
        <!-- Audio local -->
        <div class="form-group mb-4">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="esAudioLocal" name="esAudioLocal" value="true">
                <label for="esAudioLocal" class="form-check-label">
                    El disco usa audio local
                </label>
            </div>
        </div>
        <!-- Botones -->
        <div class="d-flex justify-content-between mt-4">
            <a href="/discos/1" class="btn btn-volver">
                ← Volver
            </a>
            <button class="btn btn-success">
                Guardar disco
            </button>
        </div>
    </form>
</div>
</div>
</div>
</div> 
</div>

<% include partials/_footer %>