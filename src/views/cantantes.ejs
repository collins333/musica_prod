<% include partials/_header %>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">
      Intérpretes
    </h1>
    <div class="d-flex align-items-center gap-3">
      <a href="/cantantes/nuevo" class="btn btn-primary">
        + Añadir intérprete
      </a>
      <span class="text-muted">
        Página <%= current %> de <%= paginas %>
      </span>
    </div>
  </div>
  <div class="row g-4">
    <% interpretes.forEach(interprete => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0 hover-card">
          <a href="/verCantante/<%= interprete._id %>">
            <img src="<%= interprete.caratula %>" class="card-img-top" alt="<%= interprete.nombre %>" style="height: 320px; object-fit: contain; background-color: #111;">
          </a>
          <div class="card-body">
            <h5 class="card-title fw-bold">
              <a href="/verCantante/<%= interprete._id %>" class="text-decoration-none.text-dark">
                <%= interprete.nombre %>
              </a>
            </h5>
            <p class="text-muted mb-2">
              <%= interprete.nacionalidad || 'Nacionalidad desconocida' %>
            </p>
            <small class="text-muted">
              <%= interprete.discos.length %> discos 
              <%= interprete.totalCanciones %> canciones
            </small>
          </div>
        </div>
      </div>
    <% }) %> 
  </div>
  <!-- Paginación -->
  <% if(paginas > 1) { %>
    <nav class="mt-5">
      <ul class="pagination justify-content-center">
        <% 
          const paginaActual = Number(current);
          let inicio = paginaActual - 4;
          let fin = paginaActual + 4;
          if(inicio < 1) {
            inicio = 1;
            fin = Math.min(9, paginas);
          }
          if(fin > paginas) {
            fin = paginas;
            inicio = Math.max(1, paginas - 8);
          }
        %>
        <% if(paginaActual > 1) { %>
          <li class="page-item">
            <a class="page-link" href="/cantantes/<%= paginaActual - 1 %>">
              Anterior
            </a>
          </li>
        <% } %>
        <% for(let i = inicio; i <= fin; i++) { %>
          <li class="page-item <%= i === paginaActual ? 'active' : '' %>">
            <a class="page-link" href="/cantantes/<%= i %>">
              <%= i %>
            </a>
          </li>
        <% } %>
        <% if(paginaActual < paginas) { %>
          <li class="page-item">
            <a class="page-link" href="/cantantes/<%= paginaActual + 1 %>">
              Siguiente
            </a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>

<% include partials/_footer %>