<% include partials/_header %>

<div class="container">
  <!-- Cabecera disco -->
  <div class="card shadow-lg border-0 mb-5">
    <div class="row g-0">
      <!-- Carátula -->
      <div class="col-lg-4 text-center p-4">
        <img src="<%= disco.caratula %>" alt="<%= disco.titulo %>" class="img-fluid rounded shadow" style="max-height: 450px; object-fit: contain; background-color: #111;">
      </div>
      <!-- Información -->
      <div class="col-lg-8">
        <div class="card-body h-100 d-flex flex-column justify-content-center">
          <h1 class="display-5 fw-bold mb-3">
            💿 <%= disco.titulo %>
          </h1>
          <h3 class="mb-3">
            <a href="/verCantante/<%= disco.interprete._id %>" class="text-decoration-none">
              <%=disco.interprete.nombre %>
            </a>
          </h3>
          <p class="text-muted mb-3">
            📅 Año publicación: <%= disco.anyo %>
          </p>
          <% if(disco.info) { %>
            <div class="alert alert-dark">
              <%= disco.info %>
            </div>
          <% } %>
          <!-- Botones crud -->
          <% if(user) { %>
            <div class="d-flex flex-wrap gap-2 mt-3">
              <a href="/editDisco/<%= disco._id %>" class="btn btn-success">
                Editar disco
              </a>
              <form action="/deleteDisco/<%= disco._id %>?_method=DELETE" method="post">
                <input type="hidden" name="_method" value="DELETE">
                <button class="btn btn-danger delete" type="submit">
                  Eliminar disco
                </button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <!-- Canciones -->
  <div class="mb-4">
    <h2 class="mb-4">
      🎵 Canciones del disco
    </h2>
    <div class="row g-4">
      <% disco.canciones.forEach((cancion, index) => { %>
        <div class="col-12">
          <div class="card shadow-sm border-0">
            <div class="card-body">
              <div class="row align-items-center">
                <!-- Número -->
                <div class="col-md-1 text-center">
                  <span class="fs-4 fw-bold text-muted">
                    <%= index + 1 %>
                  </span>
                </div>
                <!-- Info -->
                <div class="col-md-5">
                  <h5 class="mb-1">
                    <a href="/verCancion/<%= cancion._id %>" class="text-decoration-none">
                      <%- include('partials/cancionItem', { cancion }) %>
                    </a>
                    <% if(cancion.artista_pista) { %>
                      <span class="text muted">
                        - <em><%= cancion.artista_pista %></em>
                      </span>
                    <% } %>
                  </h5>
                  <small class="text-muted">
                    ⏱ <%= cancion.dur_cancion %>
                  </small>
                </div>
                <!-- Reproductor / YouTube-->
                <div class="col-md-4">
                  <% if(disco.esAudioLocal) { %>
                    <audio controls style="width: 100%;">
                      <source src="<%= cancion.enlace %>" type="audio/mpeg">
                    </audio>
                  <% } else { %>
                    <a href="<%= cancion.enlace %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline-danger btn-sm">
                      ▶ Ver / escuchar
                    </a>
                  <% } %>
                </div>
                <!-- Acciones -->
                <% if(user) { %>
                  <div class="col-md-2 text-end">
                    <a href="/editCancion/<%= cancion._id %>" class="btn btn-outline-success btn-sm mb-2">
                      Editar
                    </a>
                    <form action="/deleteCancion/<%= cancion._id %>?_method=DELETE" method="post">
                      <input type="hidden" name="_method" value="DELETE">
                      <button class="btn btn-outline-danger btn-sm delete" type="submit">
                        Eliminar
                      </button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <!-- Volver -->
  <div class="text-center mb-5">
    <a href="/discos/1" class="btn btn-volver">
      Volver a discos
    </a>
  </div>
</div>
<script>
  let botones = document.getElementsByClassName('delete')
  for(let i=0; i<botones.length; i+=1) {
    botones[i].addEventListener('click', (e) => {
      let respuesta = confirm('Estás seguro de querer eliminar este disco?')
      if(!respuesta){
        e.preventDefault()
      }
    })
  }
</script>

<% include partials/_footer %>