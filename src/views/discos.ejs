<% include partials/_header %>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold">
      Discos
    </h1>
    <div class="d-flex align-items-center gap-3">
      <a href="/discos/nuevo" class="btn btn-primary">
        + Añadir disco
      </a>
      <span class="text-muted">
        Página <%= current %> de <%= paginas %>
      </span>
    </div>
  </div>
  <div class="row g-4">
    <% discos.forEach(disco => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0 hover-card">
          <a href="/verDisco/<%= disco._id %>">
            <img src="<%= disco.caratula %>" class="card-img-top" alt="<%= disco.titulo %>" style="height: 320px; object-fit: contain; background-color: #111;">
          </a>
          <div class="card-body">
            <h5 class="card-title fw-bold">
              <a href="/verDisco/<%= disco._id %>" class="text-decoration-none text-light">
                <%= disco.titulo %>
              </a>
            </h5>
            <p class="mb-1">
              <a href="/verCantante/<%= disco.interprete._id %>" class="text-decoration-none">
                <%= disco.interprete.nombre %>
              </a>
            </p>
            <small class="text-muted">
              <%= disco.anyo %>
            </small>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  <!-- PAGINACIÓN -->
  <% if(paginas > 1) { %>
    <nav class="mt-5">
      <ul class="pagination justify-content-center">
        <% if(current > 1) { %>
          <li class="page-item">
            <a class="page-link" href="/discos/<%= current - 1 %>">
              Anterior
            </a>
          </li>
        <% } %>
        <%
         const paginaActual = Number(current);
         let inicio = paginaActual - 4;
         let fin = paginaActual + 4;
         if(inicio < 1) {
          inicio = 1;
          fin = Math.min(9, paginas);
         }
         if(fin > paginas) {
          fin = paginas;
          inicio = Math.max(1, paginas - 8);
         }
        %>
        <% for(let i = inicio; i <= fin; i++) { %>
          <li class="page-item <%= i === paginaActual ? 'active' : '' %>">
            <a class="page-link" href="/discos/<%= i %>">
              <%= i %>
            </a>
          </li>
        <% } %>
        <% if(current < paginas) { %>
          <li class="page-item">
            <a class="page-link" href="/discos/<%= Number(current) + 1 %>">
              Siguiente
            </a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
</div>

<% include partials/_footer %>