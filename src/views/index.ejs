<% include partials/_header %>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <h1 class="mb-4 fw-bold">
            🎵 Mi colección de música
          </h1>
          <p class="text-muted mb-5">
            Explora intérpretes, discos y canciones de tu base de datos
          </p>
          <div class="row g-4">
            <!-- Cantantes -->
            <div class="col-md-4">
              <a href="/cantantes/1" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm hover-card">
                  <img src="/img/cantantes.png" class="card-img-top p-3" alt="">
                  <div class="card-body">
                    <h5 class="card-title">Intérpretes</h5>
                  </div>
                </div>
              </a>
            </div>
            <!-- Discos -->
             <div class="col-md-4">
              <a href="/discos/1" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm hover-card">
                  <img src="/img/discos.png" class="card-img-top p-3" alt="">
                  <div class="card-body">
                    <h5 class="card-title">Discos</h5>
                  </div>
                </div>
              </a>
             </div>
             <!-- Canciones -->
              <div class="col-md-4">
                <a href="/canciones/1" class="text-decoration-none">
                  <div class="card h-100 border-0 shadow-sm hover-card">
                    <img src="/img/canciones.png" class="card-img-top p-3" alt="">
                    <div class="card-body">
                      <h5 class="card-title">Canciones</h5>
                    </div>
                  </div>
                </a>
              </div>
          </div>
        </div>
      </div>
    </div>
